# OrbitalBasis — variáveis de ambiente

# RAG: deterministic | hybrid | llm
ORBITAL_RAG_MODE=hybrid

# OpenAI (opcional — modo llm)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Dashboard consumindo API Docker
# ORBITAL_USE_API=true
# ORBITAL_API_URL=http://api:8000

# Umidade: por padrão usa o slider/query; true = substituir por ESP32
# ORBITAL_USE_TELEMETRY_SOIL=false
